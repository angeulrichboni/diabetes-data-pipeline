MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
AIRFLOW_UID= # generate with echo "AIRFLOW_UID=$(id -u)" > .env

#Postgres env values
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB= 

# ---------------- Added/standardized variables ----------------
# Compose/project
COMPOSE_PROJECT_NAME=
AIRFLOW_PROJ_DIR=.

# Postgres host port published on the host (change if 5432 is busy)
POSTGRES_HOST_PORT=

# Airflow DB connection will re-use the Postgres service above
AIRFLOW_DB_HOST=
AIRFLOW_DB_PORT=
AIRFLOW_DB_NAME=${POSTGRES_DB}
AIRFLOW_DB_USER=${POSTGRES_USER}
AIRFLOW_DB_PASSWORD=${POSTGRES_PASSWORD}

# Redis (no auth by default; set if you enable Redis ACL)
REDIS_PASSWORD=

# Airflow settings
# Generate a Fernet key and paste here to encrypt connections/variables
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
_AIRFLOW_WWW_USER_USERNAME=
_AIRFLOW_WWW_USER_PASSWORD=
_PIP_ADDITIONAL_REQUIREMENTS=
AIRFLOW_IMAGE_NAME=apache/airflow:2.9.3

# MinIO published ports (adjust if needed)
MINIO_API_HOST_PORT=
MINIO_CONSOLE_HOST_PORT=